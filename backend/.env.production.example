# Copy this file to backend/.env before running the production compose stack.

# Docker Compose database container settings
POSTGRES_DB=vibeshopping
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-db-password

# Database
DATABASE_URL=postgresql+asyncpg://postgres:change-this-db-password@db:5432/vibeshopping

# JWT
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=vibeshopping-assets

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ORIGINS=["https://your-frontend-domain.com"]

# App
APP_ENV=production
DEBUG=false
